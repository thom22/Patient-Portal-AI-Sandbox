# SmartRep AI Sandbox — Configuration
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# The app reads this file automatically on startup. No extra installs needed.

# ── Mode ──────────────────────────────────────────────────────────────────────
# "simulation" = mock AI responses, no API key needed (default)
# "live"       = calls Azure OpenAI with real LLM inference
SMARTREP_MODE=simulation

# ── Azure OpenAI credentials (required only when SMARTREP_MODE=live) ─────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_MODEL=gpt-4

# ── NLP model options (optional) ─────────────────────────────────────────────
# Set to "true" to enable spaCy/scispaCy for better de-identification.
# Requires: pip install spacy && python -m spacy download en_core_web_sm
USE_SPACY=false
# Requires: pip install scispacy && pip install <scispacy model URL>
USE_SCISPACY=false
